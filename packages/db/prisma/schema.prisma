generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// ENUMS
//

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

enum JobStatus {
  QUEUED
  CLAIMED
  RUNNING
  COMPLETED
  FAILED
  DEAD_LETTER
}

enum RetryStrategy {
  FIXED
  LINEAR
  EXPONENTIAL
}

enum WorkerStatus {
  ACTIVE
  DRAINING
  STOPPED
}

enum ExecutionStatus {
  RUNNING
  SUCCEEDED
  FAILED
}

//
// AUTH / PROJECTS
//

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(VIEWER)
  createdAt    DateTime @default(now())
}

model Project {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  queues Queue[]
}

//
// RETRY POLICY
//

model RetryPolicy {
  id          String         @id @default(uuid())
  name        String         @unique
  strategy    RetryStrategy
  baseDelayMs Int
  maxAttempts Int
  maxDelayMs  Int?
  createdAt   DateTime       @default(now())

  queues Queue[]
}

//
// QUEUES
//

model Queue {
  id                 String       @id @default(uuid())
  projectId          String
  name               String
  description        String?
  isPaused           Boolean      @default(false)
  defaultPriority    Int          @default(5)
  concurrencyLimit   Int          @default(5)
  retryPolicyId      String?
  rateLimitCount     Int?
  rateLimitWindowSec Int?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  retryPolicy   RetryPolicy?   @relation(fields: [retryPolicyId], references: [id], onDelete: SetNull)
  jobs          Job[]
  scheduledJobs ScheduledJob[]

  @@unique([projectId, name])
  @@index([projectId])
}

//
// WORKERS
//

model Worker {
  id              String         @id @default(uuid())
  workerName      String         @unique
  status          WorkerStatus   @default(ACTIVE)
  startedAt       DateTime       @default(now())
  lastHeartbeatAt DateTime?
  executions      JobExecution[]

  @@index([status])
}

//
// JOBS
//

model Job {
  id                String     @id @default(uuid())
  queueId           String
  jobType           String
  payloadJson       Json
  status            JobStatus  @default(QUEUED)
  priority          Int        @default(5)

  // Retry / scheduling
  attemptCount      Int        @default(0)
  maxAttempts       Int        @default(3)
  availableAt       DateTime   @default(now())

  // Optional batch grouping
  batchId           String?

  // Claim / lease metadata
  claimedByWorkerId String?
  leaseExpiresAt    DateTime?
  claimedAt         DateTime?

  // Completion / failure metadata
  completedAt       DateTime?
  lastError         String?

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  queue               Queue             @relation(fields: [queueId], references: [id], onDelete: Cascade)
  executions          JobExecution[]
  deadLetter          DeadLetterJob?

  // Workflow dependency relations
  parentDependencies  JobDependency[]   @relation("ChildDependencies")
  childDependencies   JobDependency[]   @relation("ParentDependencies")

  @@index([queueId, status, availableAt, createdAt])
  @@index([status, availableAt])
  @@index([batchId])
  @@index([claimedByWorkerId])
}

//
// JOB EXECUTION HISTORY
//

model JobExecution {
  id            String          @id @default(uuid())
  jobId         String
  workerId      String
  attemptNumber Int
  status        ExecutionStatus
  errorMessage  String?
  startedAt     DateTime        @default(now())
  finishedAt    DateTime?
  durationMs    Int?

  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([jobId, attemptNumber])
  @@index([workerId])
}

//
// DEAD LETTER QUEUE
//

model DeadLetterJob {
  id             String   @id @default(uuid())
  jobId          String   @unique
  failureReason  String
  finalAttempt   Int
  failureSummary String?
  createdAt      DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

//
// WORKFLOW DEPENDENCIES
// child job can run only after all parent jobs are COMPLETED
//

model JobDependency {
  id          String   @id @default(uuid())
  parentJobId String
  childJobId  String
  createdAt   DateTime @default(now())

  parentJob Job @relation("ParentDependencies", fields: [parentJobId], references: [id], onDelete: Cascade)
  childJob  Job @relation("ChildDependencies", fields: [childJobId], references: [id], onDelete: Cascade)

  @@unique([parentJobId, childJobId])
  @@index([childJobId])
  @@index([parentJobId])
}

//
// RECURRING / SCHEDULED JOB DEFINITIONS
// A scheduler loop can materialize actual Job rows from these definitions
//

model ScheduledJob {
  id             String   @id @default(uuid())
  queueId        String
  jobType        String
  payloadJson    Json
  cronExpression String?
  nextRunAt      DateTime?
  isPaused       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  queue Queue @relation(fields: [queueId], references: [id], onDelete: Cascade)

  @@index([queueId])
  @@index([nextRunAt])
}